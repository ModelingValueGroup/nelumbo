{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Nelumbo",
  "scopeName": "source.nelumbo",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#definition-operators" },
    { "include": "#operators" },
    { "include": "#precedence" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.nelumbo",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.nelumbo" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.nelumbo" } }
        },
        {
          "name": "comment.line.double-slash.nelumbo",
          "match": "//[^\\n]*",
          "captures": { "0": { "name": "comment.line.double-slash.nelumbo" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nelumbo",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.nelumbo" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.string.end.nelumbo" } },
          "patterns": [
            {
              "name": "constant.character.escape.nelumbo",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "entity.name.tag.nelumbo",
          "match": "@[a-zA-Z_][0-9a-zA-Z_.]*"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.nelumbo",
          "match": "-?[0-9]+\\.[0-9]+"
        },
        {
          "name": "constant.numeric.integer.nelumbo",
          "match": "-?[0-9]+(#[0-9a-zA-Z]+)?"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nelumbo",
          "match": "\\b(import|private|if)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.nelumbo",
          "match": "\\b(true|false|unknown)\\b"
        }
      ]
    },
    "definition-operators": {
      "patterns": [
        {
          "name": "keyword.operator.definition.nelumbo",
          "match": "::=|::|<=>|<->|->|\\?"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.nelumbo",
          "match": "[~!@#$%^&*=+|:<>.?/-]+"
        }
      ]
    },
    "precedence": {
      "patterns": [
        {
          "name": "constant.other.precedence.nelumbo",
          "match": "#[0-9]+"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.bracket.nelumbo",
          "match": "[()\\[\\]{}]"
        },
        {
          "name": "punctuation.separator.nelumbo",
          "match": "[,;]"
        },
        {
          "name": "punctuation.quote.nelumbo",
          "match": "'"
        }
      ]
    }
  }
}
