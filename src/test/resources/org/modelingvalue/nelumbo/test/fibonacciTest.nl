
    <Relation> ::= fib(<Integer>,<Integer>)
    <Integer>  ::= fib(<Integer>)

    <Integer> a, b

    fib(0,0)
    fib(1,1)

    fib(a)=b  <== fib(a,b)
    fib(a,b)  <== a>1 & b=fib(a-1)+fib(a-2)
    
    ? fib(0)=a
    ? fib(1)=a
    ? fib(2)=a
    ? fib(3)=a
    ? fib(5)=a
    ? fib(10)=a
    ? fib(100)=a
    ? fib(1000)=a
