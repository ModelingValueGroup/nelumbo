
    import    nelumbo.strings

    <String>  a, b, c
    <Integer> d
    
    "a"="a"                 ? [()][]
    "a"!="a"                ? [][()]

    "a"="b"                 ? [][()]
    "a"!="b"                ? [()][]

    "foo"+"bar"="baz"       ? [][()]
    "foo"+"bar"="foobar"    ? [()][]
     a+"bar"="foobar"       ? [(a="foo")][..]
    "foo"+a="foobar"        ? [(a="bar")][..]
    "foo"+"bar"=a           ? [(a="foobar")][..]

    len("foo")=0            ? [][()]
    len("foo")=3            ? [()][]
    len(a)=3                ? [..][..]
    len("foo")=d            ? [(d=3)][..]

    int("123456")=123456   ? [()][]
    str(123456)="123456"   ? [()][]
    int("123457")=123456   ? [][()]
    str(123457)="123456"   ? [][()]
    
    str(123456)=a          ? [(a="123456")][..]
    str(0000123456)=a      ? [(a="123456")][..]
    int("123456")=d        ? [(d=123456)][..]
    int("0000123456")=d    ? [(d=123456)][..]
    
    int("    123456")=d    ? [][..]
    int("123456    ")=d    ? [][..]
    int("NaN")=d           ? [][..]
    int("Hello, World!")=d ? [][..]
